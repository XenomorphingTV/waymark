include "city_map.way"

scene tavern_job

    var quest_active = false
    var conversation_depth = 0

    The barkeep slides a piece of paper across the bar.

    "There's a man who owes me. Name's Carro. Find him."

    set conversation_depth += 1
    set quest_active = true
    keep reward = 100

    choice
        where "Where do I start looking?" when conversation_depth < 3
            "Try the docks. He drinks there."
            set conversation_depth += 1
            go tavern_job
        accept "I'll find him." when quest_active
            go city_map
        refuse "Not interested."
            set quest_active = false
            finish